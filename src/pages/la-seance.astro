---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import PageHeader from '../components/PageHeader.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { seance } from '../data/content';
---

<Layout
  title="Le déroulement d’une séance de réflexologie plantaire | Stéphanie Garcia"
  description="Anamnèse, installation en fauteuil zéro gravité, relaxation, travail réflexe selon la méthode Ingham et temps d’échange : découvrez comment se déroule une séance de réflexologie d’1h à 1h30 à Bouaye."
>
  <PageHeader
    eyebrow="La séance"
    title="Comment se déroule une séance"
    lead="Bien plus qu’un massage : un véritable accompagnement, d’une heure à une heure trente, dans un cadre pensé pour le calme et la détente."
  />

  <Section bg="cream">
    <ol class="relative mx-auto max-w-3xl space-y-6">
      {seance.map((s, i) => (
        <li class="reveal relative flex gap-5" style={`--reveal-delay:${i * 90}ms`}>
          <div class="flex flex-col items-center">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-jade-500 font-display text-xl font-semibold text-white shadow-md shadow-jade-900/15">{s.n}</span>
            {i < seance.length - 1 && <span class="mt-1 w-px flex-1 bg-jade-200" aria-hidden="true"></span>}
          </div>
          <div class="flex-1 rounded-2xl border border-sand bg-white p-6 pb-7 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md hover:shadow-jade-900/5">
            <h2 class="font-display text-2xl text-ink">{s.title}</h2>
            <p class="mt-2 leading-relaxed text-ink-soft">{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <Section bg="white" width="narrow">
    <div class="grid gap-5 sm:grid-cols-3">
      {([
        ['clock', 'Durée', '1h à 1h30, entretien compris'],
        ['sparkles', 'Confort', 'Fauteuil « zéro gravité », habillé·e'],
        ['map-pin', 'Lieu', 'Au cabinet de Bouaye ou à domicile'],
      ] as const).map(([icon, t, d], i) => (
        <div
          class="reveal rounded-2xl border border-sand bg-cream/40 p-6 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-jade-900/5"
          style={`--reveal-delay:${i * 80}ms`}
        >
          <span class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-jade-100 text-jade-700">
            <Icon name={icon} size={24} />
          </span>
          <h2 class="mt-3 font-medium text-ink">{t}</h2>
          <p class="mt-1 text-sm text-ink-soft">{d}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-2xl border border-jade-200 bg-jade-50 p-6 text-center text-sm text-ink-soft">
      <strong class="text-ink">Après la séance :</strong> pensez à bien vous hydrater dans les
      24 à 48 heures pour aider votre corps à évacuer les tensions libérées.
    </div>

    <div class="mt-10 text-center">
      <Button href={site.resalibUrl} external size="lg" data-umami-event="rdv-seance">Réserver ma séance</Button>
    </div>
  </Section>
</Layout>
