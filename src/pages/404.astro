---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout
  title="Page introuvable — Stéphanie Garcia, réflexologue à Bouaye"
  description="La page que vous cherchez n’existe pas ou a été déplacée."
  noindex
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-5 py-24 text-center sm:py-32">
    <p class="font-display text-7xl font-semibold text-jade-500">404</p>
    <h1 class="mt-4 font-display text-3xl text-ink">Cette page s’est envolée</h1>
    <p class="mt-4 text-ink-soft">La page que vous cherchez n’existe pas ou a été déplacée. Revenons sur le bon chemin.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="/" size="lg">Retour à l’accueil</Button>
      <Button href="/contact/" variant="outline" size="lg">Nous contacter</Button>
    </div>
  </section>
</Layout>
