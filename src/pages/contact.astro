---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../data/site';

const { lat, lng } = site.address;
const osmSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${lng - 0.012}%2C${lat - 0.008}%2C${lng + 0.012}%2C${lat + 0.008}&layer=mapnik&marker=${lat}%2C${lng}`;
const gmapsDir = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${site.address.street}, ${site.address.postalCode} ${site.address.city}`)}`;
---

<Layout
  title="Contact & rendez-vous — Réflexologue à Bouaye | Stéphanie Garcia"
  description="Contactez Stéphanie Garcia, réflexologue plantaire au 1 rue Beauséjour à Bouaye (44830). Prise de rendez-vous par téléphone au 06 09 87 39 67, en ligne ou par e-mail. Cabinet et domicile."
>
  <PageHeader
    eyebrow="Contact"
    title="Prendre rendez-vous"
    lead="Au cabinet de Bouaye ou à domicile, uniquement sur rendez-vous. N’hésitez pas à me contacter pour toute question."
  />

  <Section bg="cream">
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Coordonnées -->
      <div class="flex flex-col gap-4">
        <div class="rounded-3xl border border-sand bg-white p-7">
          <h2 class="font-display text-2xl text-ink">Réserver en ligne</h2>
          <p class="mt-2 text-ink-soft">Consultez les disponibilités et réservez en quelques clics via Resalib.</p>
          <div class="mt-5">
            <Button href={site.resalibUrl} external size="lg" class="w-full sm:w-auto" data-umami-event="rdv-contact-resalib">Prendre rendez-vous en ligne</Button>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <a href={site.phoneHref} data-umami-event="tel-contact" class="group rounded-3xl border border-sand bg-white p-6 transition-colors hover:border-jade-300">
            <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-jade-100 text-jade-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <h3 class="mt-4 text-sm font-medium uppercase tracking-wider text-ink-soft">Téléphone</h3>
            <p class="mt-1 font-display text-xl text-ink group-hover:text-jade-700">{site.phone}</p>
          </a>

          <a href={site.emailHref} data-umami-event="email-contact" class="group rounded-3xl border border-sand bg-white p-6 transition-colors hover:border-jade-300">
            <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-jade-100 text-jade-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
            </span>
            <h3 class="mt-4 text-sm font-medium uppercase tracking-wider text-ink-soft">E-mail</h3>
            <p class="mt-1 break-all text-sm text-ink group-hover:text-jade-700">{site.email}</p>
          </a>
        </div>

        <div class="rounded-3xl border border-sand bg-white p-7">
          <div class="flex items-start gap-4">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-jade-100 text-jade-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <h3 class="text-sm font-medium uppercase tracking-wider text-ink-soft">Le cabinet</h3>
              <address class="mt-1 not-italic leading-relaxed text-ink">
                {site.address.street}<br />
                {site.address.postalCode} {site.address.city}
              </address>
              <a href={gmapsDir} target="_blank" rel="noopener noreferrer" class="mt-2 inline-block text-sm font-medium text-jade-700 hover:underline">Itinéraire →</a>
            </div>
          </div>
          <div class="mt-5 flex items-start gap-4 border-t border-sand pt-5">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-jade-100 text-jade-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <div>
              <h3 class="text-sm font-medium uppercase tracking-wider text-ink-soft">Horaires</h3>
              <p class="mt-1 text-ink">Uniquement sur rendez-vous</p>
              <p class="text-sm text-ink-soft">Au cabinet ou à domicile</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Carte -->
      <div class="overflow-hidden rounded-3xl border border-sand bg-white">
        <iframe
          title="Localisation du cabinet de Stéphanie Garcia à Bouaye"
          src={osmSrc}
          class="h-full min-h-[420px] w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </Section>
</Layout>
