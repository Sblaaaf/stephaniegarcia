---
// Barre d'action fixe en bas d'écran sur mobile — accès permanent à l'appel et au RDV.
import { site } from '../data/site';
---

<div class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 gap-2 border-t border-sand bg-white/95 p-2.5 backdrop-blur-md lg:hidden">
  <a
    href={site.phoneHref}
    data-umami-event="tel-mobile-bar"
    class="inline-flex items-center justify-center gap-2 rounded-full border border-jade-600 px-4 py-2.5 text-sm font-medium text-jade-700"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    Appeler
  </a>
  <a
    href={site.resalibUrl}
    target="_blank"
    rel="noopener noreferrer"
    data-umami-event="rdv-mobile-bar"
    class="inline-flex items-center justify-center gap-2 rounded-full bg-jade-500 px-4 py-2.5 text-sm font-medium text-white"
  >
    Prendre RDV
  </a>
</div>
