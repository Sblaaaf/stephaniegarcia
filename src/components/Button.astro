---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'md' | 'lg';
  external?: boolean;
  class?: string;
  'data-umami-event'?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'group/btn inline-flex items-center justify-center gap-2 rounded-full font-medium transition-[transform,background-color,box-shadow,border-color] duration-300 ease-out hover:-translate-y-0.5 active:translate-y-0 focus-visible:outline-2 focus-visible:outline-offset-2';

const variants = {
  primary:
    'bg-jade-500 text-white shadow-lg shadow-jade-900/15 hover:bg-jade-600 hover:shadow-xl hover:shadow-jade-900/25',
  outline: 'border border-jade-600 text-jade-700 hover:bg-jade-50 hover:border-jade-700',
  ghost: 'text-jade-700 hover:bg-jade-50',
};

const sizes = {
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const extAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  class:list={[base, variants[variant], sizes[size], className]}
  {...extAttrs}
  {...rest}
>
  <slot />
</a>
