# ---------------------------------------------------------------------------
# Site statique Astro — Stéphanie Garcia
# ---------------------------------------------------------------------------

# Priorité au HTML (empêche tout index.php résiduel de prendre le dessus)
DirectoryIndex index.html

RewriteEngine On

# Force HTTPS + domaine non-www canonique
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://stephaniegarcia.fr%{REQUEST_URI} [L,R=301]

# Cache long pour les assets versionnés (immutables)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|svg|png|jpe?g|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Le HTML ne doit jamais être mis en cache agressivement
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Page 404 personnalisée (générée par Astro)
ErrorDocument 404 /404.html
